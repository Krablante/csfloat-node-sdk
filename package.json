{
  "name": "csfloat-node-sdk",
  "version": "0.7.0",
  "description": "Live-validated Node.js / TypeScript SDK for the CSFloat API and public companion surfaces.",
  "homepage": "https://github.com/Krablante/csfloat-node-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krablante/csfloat-node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Krablante/csfloat-node-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "csfloat-node-sdk": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "examples",
    "API_COVERAGE.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "check": "tsc --noEmit",
    "check:node": "for file in examples/*.mjs scripts/live-*.mjs; do node --check \"$file\"; done",
    "cli:help": "node dist/cli.js help",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run check:node && npm run build && npm run cli:help && npm run pack:check",
    "test": "vitest run",
    "example:basic": "node --env-file=.env examples/basic.mjs",
    "example:buy-order": "node --env-file=.env examples/buy-order-expression.mjs",
    "example:market": "node --env-file=.env examples/market-public-feeds.mjs",
    "example:watchlist": "node --env-file=.env examples/watchlist-stall-iteration.mjs",
    "example:loadout": "node --env-file=.env examples/loadout-companion.mjs",
    "audit:live": "CSFLOAT_AUDIT_SCOPE=core node scripts/live-api-audit.mjs",
    "audit:live:extended": "CSFLOAT_AUDIT_SCOPE=extended node scripts/live-api-audit.mjs",
    "audit:shapes": "node scripts/live-shape-audit.mjs",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "csfloat",
    "csfloat-api",
    "cs2",
    "cs2-skins",
    "steam",
    "skins",
    "marketplace",
    "cli",
    "sdk",
    "typescript",
    "nodejs",
    "api-wrapper"
  ],
  "author": "G626 <gkrablante@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
